DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vacation_home?schema=public"
SESSION_SECRET="change-this-in-development"
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# Resend — search invite emails + magic link sign-in
# RESEND_API_KEY=""
# RESEND_FROM_EMAIL="onboarding@yourdomain.com"

# Google Maps — Geocoding API + Distance Matrix API + Directions API
# GOOGLE_MAPS_API_KEY=""

# Zillow URL import uses ZillAPI (not Puppeteer)
# ZILLAPI_KEY=""
# ADMIN_EMAIL=""

# Puppeteer — YachtWorld browser fallback (headless in production)
# Local debug only — never set these in production:
# PUPPETEER_HEADLESS=false
# PUPPETEER_DEBUG=true
# PUPPETEER_DEBUG_PAUSE_MS=10000
# PUPPETEER_SLOW_MO=50
# PUPPETEER_DEVTOOLS=true
# PUPPETEER_USE_SYSTEM_CHROME=true

# Production Docker image sets this to system Chromium automatically.
# PUPPETEER_EXECUTABLE_PATH="/usr/bin/chromium"
# PUPPETEER_SKIP_DOWNLOAD=true

# Legacy — unused by Zillow URL import
ZILLOW_FETCH_METHOD="puppeteer"
