generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RegionStatus {
  researching
  shortlisted
  ruled_out
  purchased
}

enum ListingStatus {
  active
  pending
  sold
  off_market
  interested
  passed
}

enum CommentTargetType {
  region
  lake
  listing
  marina
}

enum SearchMemberRole {
  owner
  editor
  viewer
}

enum PoiType {
  current_home
  work
  school
  family
  other
}

enum AssetType {
  home
  boat
  rv
}

enum BoatPropulsion {
  sail
  motor
  other
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  password         String?
  showCompAnalysis Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  comments      Comment[]
  searchMembers SearchMember[]
  invitesSent   SearchInvite[] @relation("InvitesSent")
  searchesCreated Search[]     @relation("SearchesCreated")
}

model MagicToken {
  id        String   @id @default(uuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

model Session {
  sid    String   @id
  sess   Json     @db.JsonB
  expire DateTime @db.Timestamp(6)

  @@map("session")
  @@index([expire])
}

model Search {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  assetType   AssetType @default(home)
  /// Category-level tradeoffs (newline-separated list items).
  pros        String?
  /// Category-level tradeoffs (newline-separated list items).
  cons        String?
  /// Structured must-have rules (JSON array of { id, field, op, value }).
  mustHaves   Json?     @db.JsonB
  /// Structured nice-to-have rules (JSON array of { id, field, op, value }).
  niceToHaves Json?     @db.JsonB
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy     User              @relation("SearchesCreated", fields: [createdById], references: [id], onDelete: Cascade)
  members       SearchMember[]
  invites       SearchInvite[]
  pois          PointOfInterest[]
  regions       Region[]
  marinas       Marina[]
  boatMakes     BoatMake[]
  listings      Listing[]
  pricingModels PricingModel[]

  @@index([assetType])
}

/// Search-scoped marina — the boat equivalent of a Region.
model Marina {
  id                 String   @id @default(uuid())
  searchId           String
  name               String
  slug               String
  description        String?
  address            String?
  city               String?
  state              String?
  latitude           Float?
  longitude          Float?
  driveTimeMinutes   Int?
  driveDistanceMiles Float?
  website            String?
  /// Slip pricing options — JSON array of { name, feeType, feeAmount, feePeriod, maxLengthFt?, notes? }.
  slipOptions        Json?    @db.JsonB
  /// Annual winter haul-out + storage cost.
  winterStorageCost  Int?
  liveaboardAllowed  Boolean  @default(false)
  /// Month marina opens (1-12), null if year-round.
  seasonOpen         Int?
  /// Month marina closes (1-12), null if year-round.
  seasonClose        Int?
  yearRound          Boolean  @default(true)
  /// Free-text amenities (fuel, pumpout, electric, showers, etc.).
  amenities          String?
  maxLengthFt        Float?
  maxDraftFt         Float?
  pros               String?
  cons               String?
  notes              String?
  overallScore       Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  search   Search    @relation(fields: [searchId], references: [id], onDelete: Cascade)
  listings Listing[]

  @@unique([searchId, slug])
  @@index([searchId])
}

/// Search-scoped boat manufacturer notes (pros/cons cascade onto listings).
model BoatMake {
  id          String   @id @default(uuid())
  searchId    String
  name        String
  slug        String
  description String?
  pros        String?
  cons        String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  search   Search      @relation(fields: [searchId], references: [id], onDelete: Cascade)
  models   BoatModel[]
  listings Listing[]

  @@unique([searchId, slug])
  @@index([searchId])
}

/// Model under a make; notes + encyclopedia specs cascade onto matching boats.
model BoatModel {
  id          String   @id @default(uuid())
  makeId      String
  name        String
  slug        String
  /// Optional free-text overview (user notes), not for machine specs.
  description String?
  pros        String?
  cons        String?
  notes       String?

  /// Encyclopedia / sailboatdata specs (imperial preferred).
  hullType           String?
  rigType            String?
  loaFt              Float?
  lwlFt              Float?
  beamFt             Float?
  draftFt            Float?
  displacementLb     Float?
  ballastLb          Float?
  /// Ballast as percent of displacement (e.g. 29.73).
  ballastRatio       Float?
  sailAreaSqFt       Float?
  construction       String?
  designer           String?
  builder            String?
  firstBuilt         Int?
  lastBuilt          Int?
  builtCount         Int?
  saDispl            Float?
  dispLen            Float?
  comfortRatio       Float?
  capsizeRatio       Float?
  hullSpeedKn        Float?
  engineMake         String?
  engineType         String?
  engineHp           Float?
  fuelGal            Float?
  waterGal           Float?
  sailboatDataUrl    String?
  sailboatDataFetchedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  make     BoatMake  @relation(fields: [makeId], references: [id], onDelete: Cascade)
  listings Listing[]

  @@unique([makeId, slug])
  @@index([makeId])
}

model SearchMember {
  id       String           @id @default(uuid())
  searchId String
  userId   String
  role     SearchMemberRole @default(editor)
  joinedAt DateTime         @default(now())

  search Search @relation(fields: [searchId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([searchId, userId])
  @@index([userId])
}

model SearchInvite {
  id          String           @id @default(uuid())
  searchId    String
  email       String
  role        SearchMemberRole @default(editor)
  token       String           @unique @default(uuid())
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime         @default(now())

  search    Search @relation(fields: [searchId], references: [id], onDelete: Cascade)
  invitedBy User   @relation("InvitesSent", fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([searchId, email])
  @@index([token])
}

model PointOfInterest {
  id        String   @id @default(uuid())
  searchId  String
  type      PoiType  @default(other)
  label     String
  address   String?
  city      String?
  state     String?
  zip       String?
  latitude  Float?
  longitude Float?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  search    Search           @relation(fields: [searchId], references: [id], onDelete: Cascade)
  commutes  ListingCommute[]

  @@index([searchId])
}

model Region {
  id                 String       @id @default(uuid())
  searchId           String
  name               String
  slug               String
  description        String?
  centerAddress      String?
  latitude           Float?
  longitude          Float?
  driveTimeMinutes   Int?
  driveDistanceMiles Float?
  radiusMiles        Float?
  pros               String?
  cons               String?
  overallScore       Int?
  status             RegionStatus @default(researching)
  notes              String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  search   Search    @relation(fields: [searchId], references: [id], onDelete: Cascade)
  lakes    Lake[]
  listings Listing[]

  @@unique([searchId, slug])
  @@index([searchId])
}

model Lake {
  id           String   @id @default(uuid())
  name         String
  acreage      Float?
  maxDepthFeet Float?
  avgDepthFeet Float?
  waterClarity String?
  edgeType     String?
  notes        String?
  dnrSourceUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  regionId String
  region   Region @relation(fields: [regionId], references: [id], onDelete: Cascade)

  listings Listing[]

  @@index([regionId])
}

model Listing {
  id                 String          @id @default(uuid())
  searchId           String
  sourceUrl          String?
  sourceSite         String?
  mlsNumber          String?
  status             ListingStatus   @default(active)
  address            String?
  city               String?
  state              String?         @default("WI")
  zip                String?
  latitude           Float?
  longitude          Float?
  driveTimeMinutes   Int?
  driveDistanceMiles Float?
  listPrice          Int?
  soldPrice          Int?
  isVacantLot        Boolean         @default(false)
  bedrooms           Float?
  bathrooms          Float?
  sqftLiving         Int?
  sqftLot            Int?
  acres              Float?
  yearBuilt          Int?
  waterfront         Boolean         @default(false)
  waterfrontType     String?
  /// Boat length overall (feet).
  lengthFt           Float?
  /// Listing dimensions / tanks from YachtWorld (for model cross-check).
  lwlFt              Float?
  beamFt             Float?
  draftFt            Float?
  /// Optional secondary draft (e.g. board up / drive-up).
  draftMinFt         Float?
  displacementLb     Float?
  ballastLb          Float?
  engineMake         String?
  engineModel        String?
  engineHp           Float?
  engineHours        Float?
  fuelGal            Float?
  waterGal           Float?
  hullMaterial       String?
  keelType           String?
  make               String?
  model              String?
  /// Optional friendly name for this hull (shown after make/model).
  nickname           String?
  propulsion         BoatPropulsion?
  pros               String?
  cons               String?
  notes              String?
  interestLevel      Int?
  shortlisted        Boolean         @default(false)
  shortlistRank      Int?
  /// Financing
  downPaymentPct     Float?
  interestRate       Float?
  loanTermYears      Int?
  /// Annual costs
  annualInsurance    Int?
  annualTax          Int?
  annualMaintenance  Int?
  /// Which slip option index on the linked marina the user selected.
  preferredSlipIndex Int?
  /// Custom cost line items — JSON array of { name, annualCost }.
  additionalCosts    Json?           @db.JsonB
  visited            Boolean         @default(false)
  visitNotes         String?
  listingDate        DateTime?
  daysOnMarket       Int?
  photoUrls          Json?           @db.JsonB
  rawScrapedData     Json?           @db.JsonB
  fetchedAt          DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  search   Search  @relation(fields: [searchId], references: [id], onDelete: Cascade)
  /// Required for home Searches; optional for boats/RVs.
  regionId String?
  region   Region? @relation(fields: [regionId], references: [id], onDelete: Cascade)

  lakeId String?
  lake   Lake?   @relation(fields: [lakeId], references: [id], onDelete: SetNull)

  marinaId String?
  marina   Marina? @relation(fields: [marinaId], references: [id], onDelete: SetNull)

  boatMakeId String?
  boatMake   BoatMake? @relation(fields: [boatMakeId], references: [id], onDelete: SetNull)

  boatModelId String?
  boatModel   BoatModel? @relation(fields: [boatModelId], references: [id], onDelete: SetNull)

  snapshots ListingSnapshot[]
  commutes  ListingCommute[]

  @@index([searchId])
  @@index([regionId])
  @@index([lakeId])
  @@index([marinaId])
  @@index([boatMakeId])
  @@index([boatModelId])
  @@index([isVacantLot])
  @@index([status])
  @@index([propulsion])
  @@index([shortlisted])
}

model ListingCommute {
  id                 String   @id @default(uuid())
  listingId          String
  poiId              String
  driveTimeMinutes   Int?
  driveDistanceMiles Float?
  calculatedAt       DateTime @default(now())

  listing Listing         @relation(fields: [listingId], references: [id], onDelete: Cascade)
  poi     PointOfInterest @relation(fields: [poiId], references: [id], onDelete: Cascade)

  @@unique([listingId, poiId])
  @@index([listingId])
  @@index([poiId])
}

model ListingSnapshot {
  id           String         @id @default(uuid())
  listPrice    Int?
  soldPrice    Int?
  status       ListingStatus?
  daysOnMarket Int?
  capturedAt   DateTime       @default(now())

  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([capturedAt])
}

model Comment {
  id         String            @id @default(uuid())
  body       String
  targetType CommentTargetType
  targetId   String
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId])
  @@index([userId])
}

model IngestApiCall {
  id             String   @id @default(uuid())
  searchId       String?
  userId         String?
  provider       String
  endpoint       String
  success        Boolean
  httpStatus     Int?
  creditsCharged Boolean  @default(false)
  errorCode      String?
  errorMessage   String?
  sourceUrl      String?
  zpid           String?
  requestId      String?
  createdAt      DateTime @default(now())

  @@index([searchId, createdAt])
  @@index([provider, createdAt])
  @@index([success])
}

model PricingModel {
  id          String    @id @default(uuid())
  searchId    String
  name        String
  description String?
  features    Json      @db.JsonB
  algorithm   String    @default("log_size_linear_regression")
  modelData   Json?     @db.JsonB
  sampleCount Int?
  trainedAt   DateTime?
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  search Search @relation(fields: [searchId], references: [id], onDelete: Cascade)

  @@index([searchId])
}
